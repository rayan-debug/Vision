# Shared by both apps. Copy to .env at the repo root and fill in real values.
# In production, set these as environment variables in your Vercel project
# (one project for apps/web, another for apps/admin).

# Postgres connection string. Use the POOLED connection from Neon.
# Looks like: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/db?sslmode=require"

# Public site URL — used in sitemap, canonical tags, OpenGraph, JSON-LD,
# and the admin's preview iframe. In production set to your real domain.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Admin panel session secret — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# MUST be the same value in both Vercel projects (web reads it to verify
# preview tokens, admin uses it to sign sessions).
ADMIN_SESSION_SECRET="change-me-to-a-long-random-string"

# Admin bootstrap credentials — used by the seed script to create the first
# admin user. Only needed when running `npm run db:seed` locally; not required
# in Vercel after the user exists.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# Cloudinary credentials — required on the admin Vercel project for image
# uploads (Vercel's filesystem is read-only, so the local /uploads fallback
# only works in development). Sign up at https://cloudinary.com and copy
# from Dashboard → Product Environment Credentials.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
