generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PageStatus {
  DRAFT
  PUBLISHED
}

enum Role {
  ADMIN
  EDITOR
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A user-defined page on the public site. The `blocks` JSON is an ordered
// array of typed content blocks. Slugs and translatable fields are stored
// per locale so SEO works for both languages.
model Page {
  id          String     @id @default(cuid())
  slugEn      String     @unique
  slugAr      String     @unique
  // i18n: { en: { title, description, keywords }, ar: { ... } }
  i18n        Json
  blocks      Json       @default("[]")
  ogImage     String?
  // When true, the page is published but emits noindex/nofollow so search
  // engines (and AI crawlers) skip it. Use for thank-you pages, internal
  // links, etc.
  noindex     Boolean    @default(false)
  status      PageStatus @default(DRAFT)
  isHome      Boolean    @default(false)
  showInNav   Boolean    @default(true)
  navOrder    Int        @default(0)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  revisions   PageRevision[]

  @@index([status])
}

model Project {
  id          String     @id @default(cuid())
  slugEn      String     @unique
  slugAr      String     @unique
  // i18n: { en: { title, description, fullContent, client, role }, ar: { ... } }
  i18n        Json
  category    String?
  year        Int?
  tags        String[]
  coverImage  String
  images      String[]   @default([])
  featured    Boolean    @default(false)
  order       Int        @default(0)
  status      PageStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, featured])
  @@index([category])
}

model Service {
  id        String   @id @default(cuid())
  // i18n: { en: { title, description }, ar: { ... } }
  i18n      Json
  icon      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id          String     @id @default(cuid())
  slugEn      String     @unique
  slugAr      String     @unique
  // i18n: { en: { title, excerpt, content }, ar: { ... } }
  i18n        Json
  coverImage  String?
  tags        String[]
  status      PageStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, publishedAt])
}

model Media {
  id        String   @id @default(cuid())
  url       String
  filename  String
  mimeType  String
  size      Int
  width     Int?
  height    Int?
  alt       String?
  createdAt DateTime @default(now())
}

// Singleton: there is only ever one row (id = "singleton")
model SiteSettings {
  id           String   @id @default("singleton")
  // i18n: { en: { siteName, tagline, bio }, ar: { ... } }
  i18n         Json
  email        String?
  phone        String?
  location     String?
  instagram    String?
  behance      String?
  dribbble     String?
  linkedin    String?
  twitter      String?
  youtube      String?
  tiktok       String?
  pinterest    String?
  logoUrl      String?
  // Logo presentation. logoHeight is in CSS pixels (web header renders at this
  // height, scaling width automatically). logoPosition is 'left' or 'center'.
  // logoShape clips the logo: 'none' | 'rounded' | 'circle'. logoShowText
  // toggles the site-name wordmark next to the logo image.
  logoHeight   Int      @default(28)
  logoPosition String   @default("left")
  logoShape    String   @default("none")
  logoShowText Boolean  @default(true)
  faviconUrl   String?
  primaryColor String   @default("#0a0a0a")
  accentColor  String   @default("#ff4d1a")
  // Default OpenGraph image used by pages that don't define their own.
  defaultOgImage String?
  // Optional analytics. Each is an opt-in script injected into <head> by the
  // web app when set; leave blank to disable.
  gaId             String?  // e.g. "G-XXXXXXX"
  plausibleDomain  String?  // e.g. "thevision.studio"
  // Search-console verification meta values. Each emits a <meta name="…"
  // content="…"> in <head> when set. Required to claim the site in each
  // engine's webmaster tools.
  googleVerification    String?
  bingVerification      String?
  yandexVerification    String?
  // Free-form CSS appended to the public site's <head>. Use for one-off tweaks
  // without redeploying.
  customCss        String?  @db.Text
  // Translatable navigation labels — e.g. { en: { work: "Work" }, ar: { work: "الأعمال" } }
  navLabels        Json?
  // Typography. Each font name must be a Google-Fonts family ("Inter",
  // "Playfair Display", "JetBrains Mono", etc.) and is loaded lazily in the
  // web app's <head>. Leave null to use the built-in defaults.
  displayFont      String?  // headings
  bodyFont         String?  // body copy
  monoFont         String?  // <code>, captions
  // 0.85 – 1.4 multiplier applied to all clamp() heading sizes. 1 = default.
  fontScale        Float    @default(1.0)
  // Multiplier for top/bottom section padding (1 = default).
  sectionSpacing   Float    @default(1.0)
  // 'tight' | 'normal' | 'loose'
  letterSpacing    String   @default("normal")
  // AEO: structured FAQs that get rendered as FAQPage JSON-LD on the home page.
  // [{ q: { en, ar }, a: { en, ar } }, ...]
  faqs         Json     @default("[]")
  updatedAt    DateTime @updatedAt
}

enum InquiryStatus {
  NEW
  READ
  ARCHIVED
}

// Contact-form submissions from the public site. Replaces the previous hack
// of storing messages in the Media table.
model Inquiry {
  id        String        @id @default(cuid())
  name      String
  email     String
  message   String        @db.Text
  source    String?       // e.g. "contact-form", "footer", referrer
  locale    String?       // locale the visitor used
  status    InquiryStatus @default(NEW)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status, createdAt])
}

// Append-only revision history for pages. A new row is created on every save
// (debounced) so admins can preview and restore prior versions of a page.
// Capped to the most recent N revisions per page in application code.
model PageRevision {
  id          String     @id @default(cuid())
  pageId      String
  page        Page       @relation(fields: [pageId], references: [id], onDelete: Cascade)
  i18n        Json
  blocks      Json
  status      PageStatus
  ogImage     String?
  noindex     Boolean    @default(false)
  showInNav   Boolean    @default(true)
  navOrder    Int        @default(0)
  isHome      Boolean    @default(false)
  // Email of the admin who created this revision (the user that saved).
  editorEmail String?
  // Optional, short summary of what changed (auto-derived or admin-supplied).
  note        String?
  createdAt   DateTime   @default(now())

  @@index([pageId, createdAt])
}

// Lightweight audit log of admin actions. Powers the dashboard "Recent
// activity" feed and lets the admin see who changed what across the site.
model ActivityLog {
  id          String   @id @default(cuid())
  // 'page' | 'project' | 'template' | 'service' | 'testimonial' | 'settings'
  // | 'inquiry' | 'media' — kept loose so we can add entity types without a
  // migration.
  entityType  String
  entityId    String
  // Friendly label captured at write time so the feed survives deletions.
  entityName  String?
  // Who performed the action.
  userEmail   String
  // 'created' | 'updated' | 'published' | 'unpublished' | 'deleted'
  // | 'duplicated' | 'restored' | 'ai_generated'
  action      String
  // Optional free-form context (e.g. revision id, replaced count).
  meta        Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
}

// Reusable page templates. Each is a saved set of blocks the admin can drop
// into a new page as a starting point. Pre-seeded "starter" templates can be
// edited or deleted; admins can also save their own.
model PageTemplate {
  id          String   @id @default(cuid())
  // Short slug-like identifier (auto-generated, unique). Used by the legacy
  // hardcoded templates and for stable references.
  key         String   @unique
  name        String
  description String   @default("")
  // ASCII preview shown in the picker — e.g. a 6-line outline of the layout.
  preview     String   @default("")
  blocks      Json     @default("[]")
  // Pre-seeded vs user-created — both are editable, but starter templates can
  // be reseeded from `npm run seed:templates`.
  isStarter   Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
}

// Client testimonials for use in pages via the "testimonials" block.
model Testimonial {
  id          String   @id @default(cuid())
  // i18n: { en: { quote, name, role }, ar: { ... } } — name/role can be left
  // empty per-locale to fall back to the default locale.
  i18n        Json
  avatarUrl   String?
  rating      Int?     // optional 1–5 stars
  order       Int      @default(0)
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([featured, order])
}
