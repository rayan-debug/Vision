generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PageStatus {
  DRAFT
  PUBLISHED
}

enum Role {
  ADMIN
  EDITOR
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A user-defined page on the public site. The `blocks` JSON is an ordered
// array of typed content blocks. Slugs and translatable fields are stored
// per locale so SEO works for both languages.
model Page {
  id          String     @id @default(cuid())
  slugEn      String     @unique
  slugFr      String     @unique
  // i18n: { en: { title, description, keywords }, fr: { ... } }
  i18n        Json
  blocks      Json       @default("[]")
  ogImage     String?
  status      PageStatus @default(DRAFT)
  isHome      Boolean    @default(false)
  showInNav   Boolean    @default(true)
  navOrder    Int        @default(0)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status])
}

model Project {
  id          String     @id @default(cuid())
  slugEn      String     @unique
  slugFr      String     @unique
  // i18n: { en: { title, description, fullContent, client, role }, fr: { ... } }
  i18n        Json
  category    String?
  year        Int?
  tags        String[]
  coverImage  String
  images      String[]   @default([])
  featured    Boolean    @default(false)
  order       Int        @default(0)
  status      PageStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, featured])
  @@index([category])
}

model Service {
  id        String   @id @default(cuid())
  // i18n: { en: { title, description }, fr: { ... } }
  i18n      Json
  icon      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id          String     @id @default(cuid())
  slugEn      String     @unique
  slugFr      String     @unique
  // i18n: { en: { title, excerpt, content }, fr: { ... } }
  i18n        Json
  coverImage  String?
  tags        String[]
  status      PageStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, publishedAt])
}

model Media {
  id        String   @id @default(cuid())
  url       String
  filename  String
  mimeType  String
  size      Int
  width     Int?
  height    Int?
  alt       String?
  createdAt DateTime @default(now())
}

// Singleton: there is only ever one row (id = "singleton")
model SiteSettings {
  id           String   @id @default("singleton")
  // i18n: { en: { siteName, tagline, bio }, fr: { ... } }
  i18n         Json
  email        String?
  phone        String?
  location     String?
  instagram    String?
  behance      String?
  dribbble     String?
  linkedin    String?
  twitter      String?
  logoUrl      String?
  faviconUrl   String?
  primaryColor String   @default("#0a0a0a")
  accentColor  String   @default("#ff4d1a")
  // AEO: structured FAQs that get rendered as FAQPage JSON-LD on the home page.
  // [{ q: { en, fr }, a: { en, fr } }, ...]
  faqs         Json     @default("[]")
  updatedAt    DateTime @updatedAt
}
